{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WireScope",
  "version": "0.1.2",
  "identifier": "com.luna.wirescope",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "WireScope",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 700,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDEzOEI1NTVCRjdGRTdBNUQKUldSZGV2NzNXMVdMRXdjUjZBeDlOR21NQWt0K2dZTEx0Z01YMnFLOFRQR0xqNXBIMUs1WHdneGYK",
      "endpoints": [
        "https://github.com/lunDreame/wirescope/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-"
    }
  }
}
